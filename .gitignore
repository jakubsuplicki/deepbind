# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/

# Standalone Python (auto-downloaded by install-backend)
backend/.python-local/

# Standalone Node.js (auto-downloaded by bootstrap installers)
.node-local/

# Node
node_modules/
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jarvis user workspace (user data — never commit)
Jarvis/

# Environment variables
.env
.env.local

# MCP token (per-workspace secret)
app/mcp_token

# SQLite
*.db
*.db-journal

# Logs
*.log

# Bun (we use npm in CI)
bun.lock

# Desktop bundle build caches — fetched at build time by
# desktop/scripts/fetch-bundled-models.sh and fetch-ollama.sh
backend/_bundled_models/
desktop/.ollama-cache/

# Desktop build artifacts (Tauri/PyInstaller/Cargo output)
desktop/sidecar/build/
desktop/sidecar/dist/
desktop/src-tauri/binaries/
desktop/src-tauri/target/
desktop/src-tauri/gen/

# TypeScript build cache
*.tsbuildinfo
