<?xml version="1.0" encoding="UTF-8"?>
<!--
  macOS hardened-runtime entitlements for the DeepBind Tauri shell.

  Per ADR 003 §"v1 schedule risk" and §B (amendment 2026-04-29):

    - allow-jit: required by llama.cpp / future MLX paths inside the
      bundled ollama binary. The sidecar inherits the parent bundle's
      hardened-runtime, so this entitlement on the shell covers it.
    - allow-unsigned-executable-memory: required because the Python
      sidecar (PyInstaller bootloader) maps unsigned executable pages
      at startup. Without this, the sidecar launches but immediately
      SIGKILLs on macOS hardened-runtime.
    - allow-dyld-environment-variables: required so we can pass
      OLLAMA_MODELS / DYLD_LIBRARY_PATH to the bundled ollama binary
      at spawn time (real-backend; spike doesn't use it but the
      entitlement is harmless and avoids re-notarizing later).
    - disable-library-validation: required because PyInstaller's
      one-file binary unpacks shared objects to /tmp at launch and
      dlopens them; those .so files aren't signed by Apple.

  When we add the real Ollama sidecar these stay as-is. Adding entitlements
  later requires a fresh notarization round; better to set them right once.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
